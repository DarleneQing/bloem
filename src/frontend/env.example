# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Stripe (Connect Accounts v2 + checkout + hanger rentals)
# Client: publishable key only. Server: restricted key (rk_...) preferred over secret key (sk_...).
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Prefer a restricted API key with least privilege (PaymentIntents, Accounts, Transfers, Webhooks read):
# https://docs.stripe.com/keys/restricted-api-keys
STRIPE_SECRET_KEY=rk_test_...
# From `stripe listen` locally, or Dashboard → Webhooks → signing secret in production
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend Email Configuration (for Phase 1 - Email notifications)
RESEND_API_KEY=your-resend-api-key

# Resend Audience IDs — one per marketing segment.
# Create four audiences in the Resend dashboard (Audiences → Add) and paste the IDs here.
# When unset, the audience-sync layer is a no-op (signup + settings still work; nothing is pushed to Resend).
RESEND_AUDIENCE_ID_BUYER=
RESEND_AUDIENCE_ID_PENDING_SELLER=
RESEND_AUDIENCE_ID_VERIFIED_SELLER=
RESEND_AUDIENCE_ID_ADMIN=

# Application Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sentry (Optional - for Phase 9 - Error monitoring)
NEXT_PUBLIC_SENTRY_DSN=your-sentry-dsn

# Google Maps (for market location previews)
# ⚠️ NOT NEXT_PUBLIC_ - this key is used server-side only
GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Cron Job Security
# Bearer token required by supabase/functions/cleanup-expired-carts and
# cancel-overdue-rentals (manual recovery triggers). The live cron path is
# pg_cron (migrations 027 + 028) and does NOT use this secret.
CRON_SECRET=your-random-secret-token-here

# Upstash Redis (rate limiting — optional)
# When both are set, /api/carts/items and other rate-limited routes enforce
# per-user quotas via @upstash/ratelimit. When unset, rate limiting is
# transparently disabled (the routes log a single warning and continue).
# Provision a free Redis at https://console.upstash.com.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================================================
# HOW TO GET YOUR CREDENTIALS
# ============================================================================

# SUPABASE CREDENTIALS:
# 1. Go to https://app.supabase.com
# 2. Select your project
# 3. Go to Settings > API
# 4. Copy:
#    - Project URL → NEXT_PUBLIC_SUPABASE_URL
#    - anon public key → NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - service_role key → SUPABASE_SERVICE_ROLE_KEY (⚠️ Keep secret!)

# STRIPE SETUP (test mode):
# API version is pinned in code to 2026-04-22.dahlia — match Dashboard → Developers → API version.
# 1. https://dashboard.stripe.com/test — complete Connect platform profile
# 2. Developers → API keys → Create restricted key (or use sk_test_ for quick local dev)
# 3. Publishable key → NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY
# 4. Webhook endpoint (production): https://your-domain/api/webhooks/stripe
#    Events: account.updated, checkout.session.completed, payment_intent.succeeded,
#    payment_intent.payment_failed, charge.refunded, transfer.created, transfer.reversed
# 5. Local dev (required for DB updates from payments):
#    stripe listen --forward-to localhost:3000/api/webhooks/stripe
#    Copy whsec_... to STRIPE_WEBHOOK_SECRET and restart npm run dev
# 6. Apply migrations 039–042 in Supabase

# RESEND API KEY (needed for emails):
# 1. Go to https://resend.com
# 2. Create account and get API key
# 3. For now, you can use a placeholder

# ============================================================================
# SETUP INSTRUCTIONS
# ============================================================================

# 1. Copy this file to .env.local:
#    cp env.example .env.local
#
# 2. Fill in your Supabase credentials (required now)
#
# 3. Other credentials can be added later when needed
